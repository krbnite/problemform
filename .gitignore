# Ignore conda environment directory
.conda/

# Ignore VS Code settings
.vscode/

# Ignore Python artifacts
__pycache__/
*.py[cod]
*$py.class

# Ignore Python packaging/build output
build/
dist/
*.egg-info/
.eggs/
*.egg

# Ignore Python virtual environments
.venv/
venv/
env/
ENV/

# Ignore Python test/type/lint caches and coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.pyre/

# Ignore notebook checkpoints
.ipynb_checkpoints/